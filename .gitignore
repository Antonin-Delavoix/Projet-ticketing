# ==========================================
# Git ignore pour Projet Ticketing
# Angular + Node.js API + SQLite
# ==========================================

# ====================
# Node.js / NPM
# ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ====================
# Angular
# ====================
# Compiled output
/app-ticketing/dist
/app-ticketing/tmp
/app-ticketing/out-tsc
/app-ticketing/bazel-out
/app-ticketing/.angular/cache
/app-ticketing/__screenshots__/

# Build outputs
*.js.map
*.css.map

# ====================
# API Backend / Node.js
# ====================
/api-backend/dist
/api-backend/build
/api-backend/logs
*.log

# ====================
# Base de données SQLite
# ====================
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# Garder uniquement les fichiers SQL de schéma
!schema.sql
!seed.sql
!migrations/*.sql

# Fichier database.sqlite initial (Access)
/api-backend/database.sqlite

# ====================
# Tests & Coverage
# ====================
/coverage
/app-ticketing/coverage
/api-backend/coverage
/.nyc_output
/test-results
*.lcov
.cache

# ====================
# IDE / Éditeurs
# ====================
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Eclipse
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# ====================
# Système d'exploitation
# ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ====================
# Environnement
# ====================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ====================
